<!DOCTYPE html> 
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>حاسبة العمر الدقيقة</title>
    
    <!-- ميزات دعم التشغيل كتطبيق هاتف -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#6366f1">

    <style>
        :root {
            --primary-color: #6366f1;
            --secondary-color: #a855f7;
            --bg-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --glass-bg: rgba(255, 255, 255, 0.95);
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
            color: #333;
            padding: 15px;
        }

        .container {
            background: var(--glass-bg);
            padding: 2rem 1.5rem;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 450px;
            text-align: center;
        }

        h1 {
            color: var(--primary-color);
            margin-top: 0;
            margin-bottom: 1.5rem;
            font-size: 1.6rem;
        }

        .input-group {
            margin-bottom: 1.5rem;
        }

        label {
            font-weight: bold;
            display: block;
            margin-bottom: 10px;
            color: #444;
        }

        input[type="date"] {
            padding: 14px;
            border: 2px solid #e2e8f0;
            border-radius: 14px;
            outline: none;
            width: 100%;
            font-size: 1.1rem;
            text-align: center;
            transition: border-color 0.3s;
            background: white;
        }

        input[type="date"]:focus {
            border-color: var(--primary-color);
        }

        button {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 14px;
            width: 100%;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1.1rem;
            font-weight: bold;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
            transition: background 0.2s, transform 0.1s;
        }

        button:active {
            transform: scale(0.98);
            background: var(--secondary-color);
        }

        #result {
            margin-top: 1.5rem;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .result-box {
            background: #f8fafc;
            padding: 12px;
            border-radius: 14px;
            border-bottom: 4px solid var(--primary-color);
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

        .result-box span {
            display: block;
            font-size: 1.4rem;
            font-weight: 800;
            color: #1e293b;
        }

        .result-box label {
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 0;
            margin-top: 4px;
        }

        .live-seconds {
            grid-column: span 2;
            background: #fef2f2;
            border-bottom-color: #ef4444;
        }
        
        .live-seconds span {
            color: #dc2626;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>حاسبة العمر الدقيقة</h1>
    <div class="input-group">
        <label for="dob">اختر تاريخ ميلادك:</label>
        <input type="date" id="dob">
    </div>
    <button onclick="startCalculation()">احسب عمري الآن</button>

    <div id="result" style="display: none;">
        <div class="result-box">
            <span id="years">0</span>
            <label>سنة</label>
        </div>
        <div class="result-box">
            <span id="months">0</span>
            <label>شهر</label>
        </div>
        <div class="result-box">
            <span id="days">0</span>
            <label>يوم</label>
        </div>
        <div class="result-box">
            <span id="hours">0</span>
            <label>ساعة</label>
        </div>
        <div class="result-box live-seconds">
            <span id="seconds">0</span>
            <label>ثانية (مُحدثة لحظياً)</label>
        </div>
    </div>
</div>

<script>
    // تحديد الحد الأقصى لتاريخ اليوم منعاً لاختيار تاريخ مستقبلي
    document.getElementById('dob').max = new Date().toISOString().split("T")[0];

    let timer;

    function startCalculation() {
        if (timer) clearInterval(timer);
        
        const dobValue = document.getElementById('dob').value;
        if (!dobValue) {
            alert("لطفاً اختر تاريخ ميلادك أولاً!");
            return;
        }

        document.getElementById('result').style.display = 'grid';
        
        timer = setInterval(() => {
            calculateAge(dobValue);
        }, 1000);
        
        calculateAge(dobValue);
    }

    function calculateAge(birthDate) {
        const now = new Date();
        const birth = new Date(birthDate);

        let years = now.getFullYear() - birth.getFullYear();
        let months = now.getMonth() - birth.getMonth();
        let days = now.getDate() - birth.getDate();

        if (days < 0) {
            months--;
            const lastMonth = new Date(now.getFullYear(), now.getMonth(), 0);
            days += lastMonth.getDate();
        }

        if (months < 0) {
            years--;
            months += 12;
        }

        const diffInMs = now - birth;
        const totalSeconds = Math.floor(diffInMs / 1000);
        const hours = now.getHours();

        document.getElementById('years').innerText = years;
        document.getElementById('months').innerText = months;
        document.getElementById('days').innerText = days;
        document.getElementById('hours').innerText = hours;
        document.getElementById('seconds').innerText = totalSeconds.toLocaleString();
    }
</script>

</body>
</html>
